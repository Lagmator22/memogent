include_guard(GLOBAL)

set(MEM_PLATFORM_MOBILE OFF)
set(MEM_PLATFORM_DESKTOP OFF)

if(CMAKE_SYSTEM_NAME STREQUAL "iOS")
    set(MEM_PLATFORM_NAME "iOS")
    set(MEM_PLATFORM_MOBILE ON)
elseif(CMAKE_SYSTEM_NAME STREQUAL "Android")
    set(MEM_PLATFORM_NAME "Android")
    set(MEM_PLATFORM_MOBILE ON)
elseif(APPLE)
    set(MEM_PLATFORM_NAME "macOS")
    set(MEM_PLATFORM_DESKTOP ON)
elseif(UNIX)
    set(MEM_PLATFORM_NAME "Linux")
    set(MEM_PLATFORM_DESKTOP ON)
elseif(WIN32)
    set(MEM_PLATFORM_NAME "Windows")
    set(MEM_PLATFORM_DESKTOP ON)
else()
    set(MEM_PLATFORM_NAME "Unknown")
endif()
